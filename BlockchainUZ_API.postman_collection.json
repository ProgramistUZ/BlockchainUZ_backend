		{
			"name": "Sync",
			"item": [
				{
					"name": "Get Sync Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/sync/status",
							"host": ["{{baseUrl}}"],
							"path": ["api", "sync", "status"]
						},
						"description": "Returns the current synchronization status"
					},
					"response": []
				},
				{
					"name": "Trigger Manual Sync",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/sync/trigger",
							"host": ["{{baseUrl}}"],
							"path": ["api", "sync", "trigger"]
						},
						"description": "Manually trigger blockchain synchronization (requires ADMIN role)"
					},
					"response": []
				},
				{
					"name": "Sync Block Range",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/sync/range?startBlock=1&endBlock=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "sync", "range"],
							"query": [
								{
									"key": "startBlock",
									"value": "1",
									"description": "Start block number"
								},
								{
									"key": "endBlock",
									"value": "10",
									"description": "End block number"
								}
							]
						},
						"description": "Manually sync a specific range of blocks (requires ADMIN role)"
					},
					"response": []
				}
			]
		},
