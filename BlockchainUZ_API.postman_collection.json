					"response": []
				},
				{
					"name": "Search Transactions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/transactions/search?address={{walletAddress}}&page=0&size=20",
							"host": ["{{baseUrl}}"],
							"path": ["api", "transactions", "search"],
							"query": [
								{
									"key": "hash",
									"value": "",
									"description": "Transaction hash",
									"disabled": true
								},
								{
									"key": "blockNumber",
									"value": "",
									"description": "Block number",
									"disabled": true
								},
								{
									"key": "status",
									"value": "CONFIRMED",
									"description": "Transaction status",
									"disabled": true
								},
								{
									"key": "address",
									"value": "{{walletAddress}}",
									"description": "Wallet address (from or to)"
								},
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "20"
								}
							]
						},
						"description": "Search transactions with filters"
					},
					"response": []
				}
			]
		},
